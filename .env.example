# Custom (Centaur) — environment overrides for docker-compose.
# Copy to `.env` and adjust. The stack also runs without this file (the
# compose defaults below are applied), but you MUST set a strong secret key
# for any real deployment.

# Flask secret key — generate with: openssl rand -base64 42
SUPERSET_SECRET_KEY=centaur-demo-not-for-production-please-override-this-secret-key

# Metadata database (PostgreSQL)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=superset
DATABASE_PASSWORD=superset
DATABASE_DB=superset

# Redis (cache + Celery)
REDIS_HOST=redis
REDIS_PORT=6379

# Initial admin password (user is always `admin`)
ADMIN_PASSWORD=admin

# Load the example dashboards on first init (needed for the demo landing page)
SUPERSET_LOAD_EXAMPLES=yes

# Dashboard (id or slug) shown as the landing page for ALL users.
# `world_health` is one of the example dashboards.
DEFAULT_LANDING_DASHBOARD=world_health
